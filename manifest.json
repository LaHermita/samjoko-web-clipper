{
  "manifest_version": 3,
  "name": "__MSG_nombreExtension__",
  "version": "0.1.0",
  "description": "__MSG_descripcionExtension__",
  "default_locale": "es",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "options_ui": {
    "page": "opciones/opciones.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "ventana-emergente/ventana.html",
    "default_title": "__MSG_tituloAccion__",
    "default_icon": {
      "16": "assets/icons/Samjoko-Icono_Circular_16px.png",
      "32": "assets/icons/Samjoko-Icono_Circular_30px.png"
    }
  },
  "background": {
    "service_worker": "trabajador-fondo.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["extractor-contenido.js"]
    }
  ],
  "icons": {
    "16": "assets/icons/Samjoko-Icono_Circular_16px.png",
    "32": "assets/icons/Samjoko-Icono_Circular_30px.png",
    "48": "assets/icons/Samjoko-Icono_Circular_48px.png",
    "128": "assets/icons/Samjoko-Icono_Circular_128px.png"
  }
}
