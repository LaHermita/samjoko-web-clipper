{
  "manifest_version": 3,
  "name": "Samjoko Nav Extension",
  "version": "0.1.0",
  "description": "Captura el contenido de páginas web y lo convierte a Markdown",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "options_ui": {
    "page": "opciones/opciones.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "ventana-emergente/ventana.html",
    "default_title": "Samjoko Nav",
    "default_icon": {
      "16": "icons/icono-16.png",
      "32": "icons/icono-32.png"
    }
  },
  "background": {
    "service_worker": "trabajador-fondo.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["extractor-contenido.js"]
    }
  ],
  "icons": {
    "16": "icons/icono-16.png",
    "32": "icons/icono-32.png",
    "48": "icons/icono-48.png",
    "128": "icons/icono-128.png"
  }
}
